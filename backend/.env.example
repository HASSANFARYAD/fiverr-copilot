# Database (SQLite — zero config)
DATABASE_URL=sqlite+aiosqlite:///./fiverr_copilot.db

# ── AI Provider (default: Groq — free, open-source models) ──
# 1. Sign up at https://console.groq.com (free, no credit card)
# 2. Generate an API key at https://console.groq.com/keys
# 3. Paste it below
AI_PROVIDER=openai
AI_MODEL=llama-3.1-8b-instant
AI_API_KEY=
AI_API_BASE=https://api.groq.com/openai/v1
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Debug
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]

# ── Alternative Providers ──

# OpenAI
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o-mini
# AI_API_KEY=sk-...
# AI_API_BASE=

# Anthropic
# AI_PROVIDER=anthropic
# AI_MODEL=claude-3-haiku-20240307
# AI_API_KEY=sk-ant-...

# Google Gemini (free tier available)
# AI_PROVIDER=gemini
# AI_MODEL=gemini-2.0-flash
# AI_API_KEY=AIza...

# DeepSeek hosted API
# AI_PROVIDER=openai
# AI_MODEL=deepseek-chat
# AI_API_KEY=sk-...
# AI_API_BASE=https://api.deepseek.com/v1

# OpenRouter (pay-as-you-go, many models)
# AI_PROVIDER=openai
# AI_MODEL=deepseek/deepseek-chat
# AI_API_KEY=sk-or-...
# AI_API_BASE=https://openrouter.ai/api/v1

# GitHub Models (free with rate limits)
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o-mini
# AI_API_KEY=$(gh auth token)
# AI_API_BASE=https://models.inference.ai.azure.com

# Ollama (local — no API key needed)
# Install: brew install ollama && ollama pull qwen2.5
# AI_PROVIDER=ollama
# AI_MODEL=qwen2.5
# AI_API_BASE=http://localhost:11434
